<?xml version="1.0" encoding="utf-8"?>
<!-- SCREEN 7: Results / End Screen -->
<!-- Reached from GameFragment when: all pairs matched (win) OR timer hits 0 (lose) -->
<!-- TODO: Show resultMessage based on win/lose state passed via ViewModel/args -->
<!-- TODO: Populate scoreboard list from database (top 3 users for this category) -->
<!-- Actions: playAgainButton -> DifficultyFragment | homeButton -> CategoryFragment -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2D1B69"
    tools:context=".ResultsFragment">

    <!-- Win/Lose message -->
    <!-- TODO: Set text dynamically: "Congrats you matched them all!" or "Unfortunately, you ran out of time" -->
    <TextView
        android:id="@+id/resultMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Congrats you matched them all or\nUnfortunately, you ran out of time"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:gravity="start"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="64dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Congrats you matched them all!" />

    <!-- Scoreboard label -->
    <TextView
        android:id="@+id/scoreboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User Overall Score board:"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:layout_marginTop="28dp"
        app:layout_constraintStart_toStartOf="@id/resultMessage"
        app:layout_constraintTop_toBottomOf="@id/resultMessage" />

    <!-- Scoreboard card -->
    <!-- TODO: Replace TextViews with RecyclerView populated from database -->
    <androidx.cardview.widget.CardView
        android:id="@+id/scoreboardCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#3D2080"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scoreboardTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/score1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User 1: 0:05s"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="serif"
                android:layout_marginBottom="6dp"
                tools:text="User 1: 0:05s" />

            <TextView
                android:id="@+id/score2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User 2: 0:07s"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="serif"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/score3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User 3: 0:11s"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="serif" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Action buttons -->
    <Button
        android:id="@+id/playAgainButton"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginTop="24dp"
        android:text="Play Again"
        android:textColor="#FFFFFF"
        android:backgroundTint="#5535A0"
        android:textSize="15sp"
        android:stateListAnimator="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scoreboardCard" />

    <Button
        android:id="@+id/homeButton"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginTop="12dp"
        android:text="Home"
        android:textColor="#FFFFFF"
        android:backgroundTint="#3D2080"
        android:textSize="15sp"
        android:stateListAnimator="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/playAgainButton" />

</androidx.constraintlayout.widget.ConstraintLayout>